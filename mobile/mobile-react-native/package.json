    "expo-splash-screen": "55.0.17",
    "expo-status-bar": "55.0.5",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.85.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "0.21.2"
