{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "hm-panel-plugin",
  "version": "1.0.0",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "dev-grafana": "docker compose up --build",
    "test": "jest",
    "test-watch": "jest --watch",
    "test-coverage": "jest --coverage",
    "lint-javascript": "eslint .",
    "lint-javascript-fix": "eslint . --fix",
    "static-type-check-typescript": "tsc",
    "end-to-end-test": "wait-on http://localhost:3000 && playwright test",
    "end-to-end-test-report": "playwright show-report"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "12.4.2",
    "@grafana/runtime": "12.4.2",
    "@grafana/ui": "12.4.2",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@grafana/eslint-config": "9.0.0",
    "@grafana/plugin-e2e": "3.5.0",
    "@grafana/tsconfig": "2.0.1",
    "@playwright/test": "1.59.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.26",
    "@swc/helpers": "0.5.21",
    "@swc/jest": "0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "ajv": "8.18.0",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-playwright": "2.10.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-webpack-plugin": "6.0.0",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "prettier": "3.8.3",
    "replace-in-file-webpack-plugin": "1.0.6",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "wait-on": "9.0.5",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2",
    "webpack-livereload-plugin": "3.0.2",
    "webpack-subresource-integrity": "5.1.0",
    "webpack-virtual-modules": "0.6.2"
  }
}
