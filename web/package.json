{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "hm-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "sh scripts/prebuild.sh",
    "build": "tsc && vite build",
    "postbuild": "sh scripts/postbuild.sh",
    "serve": "vite preview --port=11413",
    "analyze": "vite-bundle-visualizer",
    "lint-javascript": "eslint .",
    "lint-javascript-fix": "eslint . --fix",
    "static-type-check-typescript": "tsc",
    "test": "vitest run",
    "test-watch": "vitest",
    "test-ui": "vitest --ui",
    "test-coverage": "vitest run --coverage",
    "storybook": "storybook dev --port=6006",
    "storybook-build": "storybook build",
    "storybook-publish": "chromatic --build-script-name storybook-build",
    "lighthouse": "lhci autorun",
    "shadcn": "shadcn add button card separator"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@analytics/google-tag-manager": "0.6.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.218.0",
    "@opentelemetry/instrumentation": "0.218.0",
    "@opentelemetry/instrumentation-document-load": "0.63.0",
    "@opentelemetry/instrumentation-xml-http-request": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/sdk-trace-web": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@radix-ui/react-separator": "1.1.9",
    "@radix-ui/react-slot": "1.2.5",
    "@sentry/react": "10.56.0",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.15",
    "analytics": "0.8.19",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "graphql": "16.14.2",
    "graphql-ws": "6.0.8",
    "lucide-react": "1.17.0",
    "normalize.css": "8.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-use": "17.6.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@eslint/compat": "2.1.0",
    "@eslint/js": "10.0.1",
    "@html-eslint/eslint-plugin": "0.61.0",
    "@html-eslint/parser": "0.61.0",
    "@lhci/cli": "0.15.1",
    "@storybook/react-vite": "10.4.2",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.40",
    "@tanstack/eslint-plugin-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-plugin": "1.168.18",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-hooks": "8.0.1",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "chromatic": "17.3.0",
    "eslint": "10.4.1",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-storybook": "10.4.2",
    "eslint-plugin-testing-library": "7.16.2",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "serve": "14.2.6",
    "shadcn": "4.11.0",
    "sitemap": "9.0.1",
    "source-map-explorer": "2.5.3",
    "storybook": "10.4.2",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-bundle-visualizer": "1.2.1",
    "vitest": "4.1.8"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
