{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom"],
    "types": ["node"]
  },
  "include": ["**/*.ts"]
}
