{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "web-playwright",
  "private": true,
  "type": "module",
  "scripts": {
    "lint-javascript": "eslint .",
    "lint-javascript-fix": "eslint . --fix",
    "static-type-check-typescript": "tsc",
    "end-to-end-test-8080": "wait-on http://localhost:8080 && playwright test --config=playwright.8080.config.ts",
    "end-to-end-test-58136": "wait-on http://localhost:58136 && playwright test --config=playwright.58136.config.ts",
    "end-to-end-test-ui-8080": "playwright test --config=playwright.8080.config.ts --ui",
    "end-to-end-test-ui-58136": "playwright test --config=playwright.58136.config.ts --ui",
    "end-to-end-test-report": "playwright show-report"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@types/node": "24.0.15",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "eslint": "10.1.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-playwright": "2.10.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "wait-on": "9.0.4"
  }
}
